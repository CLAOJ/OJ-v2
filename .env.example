# CLAOJ v2 - Shared Environment Configuration
# Copy this file to .env and customize for your environment
# This file contains shared configuration for both backend and frontend

# =============================================================================
# SITE CONFIGURATION (Shared)
# =============================================================================

# Base URL of your site (used by both frontend and backend)
SITE_URL=http://localhost:3000

# API URL (frontend uses this, backend derives from SITE_URL)
API_URL=http://localhost:8080/api/v2

# Default language/locale
DEFAULT_LANG=en

# =============================================================================
# DATABASE CONFIGURATION (Backend only)
# =============================================================================

# Database connection string (MySQL/MariaDB)
# Format: user:password@tcp(host:port)/database?charset=utf8mb4&parseTime=True&loc=UTC
DATABASE_URL=claoj_user:claoj_pass@tcp(127.0.0.1:3306)/claoj?charset=utf8mb4&parseTime=True&loc=UTC

# =============================================================================
# REDIS CONFIGURATION (Backend only)
# =============================================================================

REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=
REDIS_DB=0

# =============================================================================
# SERVER CONFIGURATION (Backend only)
# =============================================================================

SERVER_PORT=8080
SERVER_MODE=debug

# =============================================================================
# APPLICATION SECRETS (Backend only - NEVER commit real values!)
# =============================================================================

# Generate a secure key with: openssl rand -base64 64
SECRET_KEY=your-development-secret-key-change-in-production

# JWT Secret Key (optional - defaults to SECRET_KEY if not set)
# For better security, use a dedicated JWT secret key
# Generate with: openssl rand -base64 64
JWT_SECRET_KEY=your-development-jwt-secret-key-change-in-production

# Require TOTP/2FA for admin accounts (optional, default: false)
# Set to true to enforce two-factor authentication for all admin/staff accounts
REQUIRE_TOTP_FOR_ADMINS=false

# =============================================================================
# SECURITY SETTINGS
# =============================================================================

# Account lockout threshold (number of failed login attempts before temporary lockout)
# Default: 10 attempts
# LOCKOUT_MAX_ATTEMPTS=10

# Account lockout duration in minutes
# Default: 15 minutes
# LOCKOUT_DURATION=15

# =============================================================================
# EMAIL CONFIGURATION (Backend only - Optional)
# =============================================================================

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=noreply@example.com
FROM_NAME=CLAOJ

# =============================================================================
# OAUTH CONFIGURATION (Backend only - Optional)
# =============================================================================

# Google OAuth
OAUTH_GOOGLE_ENABLED=false
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_GOOGLE_REDIRECT_URL=${SITE_URL}/api/v2/auth/oauth/google/callback

# GitHub OAuth
OAUTH_GITHUB_ENABLED=false
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=
OAUTH_GITHUB_REDIRECT_URL=${SITE_URL}/api/v2/auth/oauth/github/callback

# =============================================================================
# FRONTEND CONFIGURATION (Frontend only)
# =============================================================================

# Site name displayed in UI
NEXT_PUBLIC_SITE_NAME=CLAOJ

# Optional: Google Analytics
NEXT_PUBLIC_GA_ID=

# Optional: Discord invite link
NEXT_PUBLIC_DISCORD_INVITE=
